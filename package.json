{
  "name": "yatriso",
  "version": "0.1.0",
  "private": true,
  "description": "Yatriso cloudflare-first taxi platform foundation",
  "workspaces": [
    "apps/web",
    "workers/api"
  ],
  "scripts": {
    "build": "npm run build:web",
    "dev:web": "npm run dev -w apps/web",
    "build:web": "npm run build -w apps/web",
    "dev:api": "wrangler dev -c workers/api/wrangler.toml",
    "deploy:api": "wrangler deploy -c workers/api/wrangler.toml",
    "deploy:api:ci": "npx wrangler deploy -c workers/api/wrangler.toml"
  }
}
